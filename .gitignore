# Ambientes Virtuais (Nunca versionar o motor do Python)
venv/
.venv/
env/

# Segurança (Nunca versionar senhas e chaves de API)
.env

# Bancos de Dados Locais (O banco deve ser gerado pelo código, não baixado)
*.db
*.sqlite
*.sqlite3

# Dados Brutos e Processados (Não versionamos volumetria, apenas o código que a gera)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Arquivos de Cache e Sistema (Sujeira que o Python e o Jupyter criam sozinhos)
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store